<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Locations</h1>
    <div class="text-sm text-gray-500">
      <%= @stats[:total] %> total,
      <%= @stats[:with_coordinates] %> with coordinates,
      <%= @stats[:precise] %> geocoded
    </div>
  </div>

  <!-- Stats by Region -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
    <% Location.dialect_regions.each_key do |region| %>
      <div class="bg-white shadow rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-gray-900"><%= @stats[:by_region][region] || 0 %></div>
        <div class="text-sm text-gray-500"><%= region.humanize %></div>
      </div>
    <% end %>
  </div>

  <!-- Search and Filter -->
  <div class="mb-4 flex flex-col md:flex-row gap-2">
    <%= form_tag admin_locations_path, method: :get, class: "flex flex-1 gap-2" do %>
      <%= hidden_field_tag :dialect_region, params[:dialect_region] if params[:dialect_region].present? %>
      <%= text_field_tag :search, params[:search],
          placeholder: "Search by name...",
          class: "flex-1 px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
      <%= submit_tag "Search", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
      <% if params[:search].present? %>
        <%= link_to "Clear", admin_locations_path(dialect_region: params[:dialect_region]),
            class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300" %>
      <% end %>
    <% end %>
  </div>

  <!-- Dialect Region Filter -->
  <div class="mb-4 flex gap-2 flex-wrap">
    <span class="text-sm text-gray-700 font-medium py-2">Region:</span>
    <%= link_to "All", admin_locations_path(search: params[:search]),
        class: "px-3 py-1 text-sm #{params[:dialect_region].blank? ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'} rounded" %>
    <% Location.dialect_regions.each_key do |region| %>
      <%= link_to region.humanize, admin_locations_path(dialect_region: region, search: params[:search]),
          class: "px-3 py-1 text-sm #{params[:dialect_region] == region ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'} rounded" %>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-x-auto mb-4">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Irish Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Region</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Coordinates</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recordings</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @locations.each do |location| %>
          <tr>
            <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= location.name %>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= location.irish_name %>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
                <%= location.dialect_region&.humanize %>
              </span>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= location.location_type&.humanize %>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if location.latitude && location.longitude %>
                <% if location.has_precise_coordinates? %>
                  <span class="text-green-600" title="Geocoded"><%= "%.4f, %.4f" % [location.latitude, location.longitude] %></span>
                <% else %>
                  <span class="text-yellow-600" title="Region center (approximate)"><%= "%.4f, %.4f" % [location.latitude, location.longitude] %></span>
                <% end %>
              <% else %>
                <span class="text-red-400">None</span>
              <% end %>
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= location.recordings_count %>
            </td>
            <td class="px-4 py-4 text-sm font-medium">
              <%= link_to "Edit", edit_admin_location_path(location), class: "text-blue-600 hover:text-blue-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @pagy.pages > 1 %>
    <div class="mt-6 border-t border-gray-200 pt-6 flex items-center justify-between">
      <div class="text-sm text-gray-700">
        Showing <span class="font-medium"><%= @pagy.from %></span> to
        <span class="font-medium"><%= @pagy.to %></span> of
        <span class="font-medium"><%= @pagy.count %></span> locations
      </div>
      <div class="flex space-x-2">
        <% if @pagy.prev %>
          <%= link_to "Previous", admin_locations_path(page: @pagy.prev, dialect_region: params[:dialect_region], search: params[:search]),
              class: "px-4 py-2 text-sm text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to "Next", admin_locations_path(page: @pagy.next, dialect_region: params[:dialect_region], search: params[:search]),
              class: "px-4 py-2 text-sm text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
