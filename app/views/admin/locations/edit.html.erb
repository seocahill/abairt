<div class="container mx-auto px-4 py-8">
  <div class="mb-6 flex items-center justify-between">
    <%= link_to "← Back to Locations", admin_locations_path, class: "text-gray-600 hover:text-gray-900" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Form -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h1 class="text-2xl font-bold text-gray-900">Edit Location</h1>
      </div>

      <%= form_with model: [:admin, @location], local: true, class: "px-6 py-6", data: { controller: "location-edit" } do |form| %>
        <% if @location.errors.any? %>
          <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-4">
            <ul class="list-disc list-inside text-sm text-red-700">
              <% @location.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-6">
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
          </div>

          <div>
            <%= form.label :irish_name, "Irish Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :irish_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :dialect_region, "Dialect Region", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.select :dialect_region,
                  options_for_select(Location.dialect_regions.keys.map { |r| [r.humanize, r] }, @location.dialect_region),
                  {},
                  { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
            </div>

            <div>
              <%= form.label :location_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.select :location_type,
                  options_for_select(Location.location_types.keys.map { |t| [t.humanize, t] }, @location.location_type),
                  { include_blank: "Not specified" },
                  { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :latitude, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.number_field :latitude, step: "any",
                  id: "location-latitude",
                  data: { location_edit_target: "latitude" },
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>

            <div>
              <%= form.label :longitude, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.number_field :longitude, step: "any",
                  id: "location-longitude",
                  data: { location_edit_target: "longitude" },
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>
          </div>

          <div>
            <p class="text-xs text-gray-500">Click on the map to set coordinates, or enter them manually above.</p>
          </div>

          <div>
            <%= form.label :parent_id, "Parent Location", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.select :parent_id,
                options_for_select(
                  Location.where.not(id: @location.id).order(:name).pluck(:name, :id),
                  @location.parent_id
                ),
                { include_blank: "None" },
                { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
          </div>
        </div>

        <div class="mt-6 pt-6 border-t border-gray-200 flex justify-between">
          <div>
            <%= button_to "Geocode", geocode_admin_location_path(@location),
                method: :post,
                class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50",
                title: "Look up coordinates via Nominatim" %>
          </div>
          <div class="flex gap-3">
            <%= link_to "Cancel", admin_locations_path, class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
            <%= form.submit "Save", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Map -->
    <div class="bg-white shadow rounded-lg overflow-hidden" data-controller="location-edit">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-lg font-semibold text-gray-900">Map</h2>
      </div>
      <div id="location-edit-map"
           data-location-edit-target="map"
           data-location-edit-lat-value="<%= @location.latitude || 53.9 %>"
           data-location-edit-lng-value="<%= @location.longitude || -9.5 %>"
           data-location-edit-has-coords-value="<%= @location.latitude.present? %>"
           style="height: 500px; width: 100%;"></div>
    </div>
  </div>

  <!-- Associated Recordings -->
  <% recordings = @location.associated_voice_recordings.limit(10) %>
  <% if recordings.any? %>
    <div class="mt-6 bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-lg font-semibold text-gray-900">
          Associated Recordings
          <span class="text-sm font-normal text-gray-500">(<%= @location.voice_recording_locations.count %> total)</span>
        </h2>
      </div>
      <ul class="divide-y divide-gray-200">
        <% recordings.each do |recording| %>
          <li class="px-6 py-3">
            <%= link_to recording.title, voice_recording_path(recording), class: "text-blue-600 hover:text-blue-900" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
