<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">All Tags</h1>
            <p class="mt-2 text-sm text-gray-600">Browse all tags used in voice recordings</p>
          </div>
          <%= link_to "Back to Recordings", voice_recordings_path,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        </div>

        <!-- Search and Sort -->
        <%= form_tag tags_voice_recordings_path, method: :get, class: "flex gap-4" do %>
          <div class="flex-1">
            <%= text_field_tag :search, params[:search],
                placeholder: "Search tags...",
                class: "w-full px-4 py-2 border rounded-lg" %>
          </div>
          <div class="flex gap-2">
            <%= select_tag :order,
                options_for_select([["Most Used", "count"], ["Name", "name"]], params[:order] || "count"),
                class: "px-4 py-2 border rounded-lg" %>
            <%= submit_tag "Filter", class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
          </div>
        <% end %>

        <!-- Alphabet Navigation -->
        <div class="flex flex-wrap gap-1 mt-4">
          <%= link_to "All", tags_voice_recordings_path(search: params[:search], order: params[:order]),
              class: "px-2 py-1 text-sm rounded #{params[:letter].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
          <% ('A'..'Z').each do |letter| %>
            <%= link_to letter, tags_voice_recordings_path(letter: letter, search: params[:search], order: params[:order]),
                class: "px-2 py-1 text-sm rounded #{params[:letter] == letter ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Tags Grid -->
    <div class="bg-white shadow rounded-lg p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @tags.each do |tag| %>
          <%= link_to voice_recordings_path(tag: tag.name), class: "flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:border-blue-500 hover:shadow-md transition-all group" do %>
            <div class="flex items-center gap-3">
              <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center group-hover:bg-blue-200">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900 group-hover:text-blue-600"><%= tag.name %></h3>
                <p class="text-sm text-gray-500"><%= pluralize(tag.taggings_count, 'recording') %></p>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
      </div>

      <!-- Pagination -->
      <% if @pagy.next %>
        <div class="mt-8 text-center">
          <%= link_to "Load More", tags_voice_recordings_path(page: @pagy.next, letter: params[:letter], search: params[:search], order: params[:order]),
              class: "inline-flex items-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
