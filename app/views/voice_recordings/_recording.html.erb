<% if recording.media.attached? %>
  <%
    pct = recording.percentage_transcribed
    progress_color = pct >= 90 ? 'bg-emerald-500' : pct >= 50 ? 'bg-amber-500' : 'bg-red-400'

    predicted = recording.analysis_speakers
    if predicted.present?
      speaker_names = predicted.map { |s| s["name"].presence }.compact
      speaker_names = predicted.map { |s| [s["gender"]&.capitalize, s["dialect_region"]&.humanize].compact.join(', ') } if speaker_names.empty?
    else
      speaker_names = recording.users.reject(&:temporary?).map(&:name)
    end

    dialects = recording.users.pluck(:dialect).uniq.compact.reject(&:blank?)
    duration = recording.dictionary_entries.maximum(:region_end)
  %>

  <div class="bg-white rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
    <!-- Play button + Audio -->
    <div class="bg-gradient-to-br from-indigo-600 to-indigo-800 p-5 flex items-center gap-4"
         data-controller="card-player"
         data-card-player-url-value="<%= url_for(recording.media) %>">
      <button data-action="click->card-player#toggle"
              data-card-player-target="button"
              class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm text-white flex items-center justify-center hover:bg-white/30 transition-colors flex-shrink-0">
        <svg data-card-player-target="playIcon" class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
        </svg>
        <svg data-card-player-target="pauseIcon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
      </button>
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-white leading-snug truncate">
          <%= link_to recording.title, voice_recording_path(recording),
              class: "hover:text-indigo-200",
              data: { turbo_frame: "_top" } %>
        </h3>
        <div class="flex items-center gap-2 mt-1">
          <div class="flex-1 bg-white/20 rounded-full h-1" data-card-player-target="progressBar">
            <div class="bg-white h-1 rounded-full w-0 transition-all" data-card-player-target="progress"></div>
          </div>
          <span class="text-xs text-indigo-200 font-mono" data-card-player-target="time">
            <%= duration.present? ? format_duration(duration) : '--:--' %>
          </span>
        </div>
      </div>
    </div>

    <div class="p-4">
      <!-- Metadata -->
      <div class="space-y-1.5 text-sm text-gray-600">
        <% if speaker_names.any? %>
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span><%= speaker_names.join(', ') %></span>
          </div>
        <% end %>

        <% if dialects.any? %>
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span><%= dialects.map(&:humanize).join(', ') %></span>
          </div>
        <% end %>

        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div class="flex items-center gap-2">
            <div class="w-16 bg-gray-200 rounded-full h-1.5">
              <div class="<%= progress_color %> h-1.5 rounded-full" style="width: <%= pct %>%"></div>
            </div>
            <span class="text-xs font-medium <%= pct >= 90 ? 'text-emerald-600' : pct >= 50 ? 'text-amber-600' : 'text-red-500' %>"><%= pct %>%</span>
          </div>
        </div>
      </div>

      <!-- Topics -->
      <% if recording.tag_list.any? %>
        <div class="mt-3 flex flex-wrap gap-1">
          <% recording.tag_list.first(4).each do |tag_name| %>
            <%= link_to tag_name,
                voice_recordings_path(view: @view_mode, tag: tag_name),
                class: "px-2 py-0.5 rounded text-xs bg-indigo-50 text-indigo-700 hover:bg-indigo-100",
                data: { turbo_frame: "recordings" } %>
          <% end %>
          <% if recording.tag_list.size > 4 %>
            <span class="text-xs text-gray-400">+<%= recording.tag_list.size - 4 %></span>
          <% end %>
        </div>
      <% end %>

      <!-- View Transcription -->
      <div class="mt-4">
        <%= link_to voice_recording_path(recording),
            class: "inline-flex items-center px-4 py-2 text-sm font-medium text-indigo-700 bg-indigo-50 rounded-lg hover:bg-indigo-100 transition-colors",
            data: { turbo_frame: "_top" } do %>
          View Transcription
          <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
